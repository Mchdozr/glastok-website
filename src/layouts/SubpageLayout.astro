---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';

interface Props {
  lang: string;
  title: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const homeHref = lang === 'en' ? '/' : '/tr/';
---

<Layout lang={lang} title={`${title} — Glastok`} description={description}>
  <Navbar lang={lang} />

  <main class="relative min-h-screen pt-32 pb-24 md:pt-40 md:pb-32">
    <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8">

      <!-- Back link -->
      <a href={homeHref} class="inline-flex items-center gap-2 text-dark-text-muted hover:text-brand-primary transition-colors mb-10 group">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        <span class="font-heading text-xs font-bold tracking-wider uppercase">{t(lang, 'subpage.backHome')}</span>
      </a>

      <slot />
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
