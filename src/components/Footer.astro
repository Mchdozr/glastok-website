---
import { t } from '../i18n/translations';

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const currentYear = new Date().getFullYear();
const p = lang === 'en' ? '' : '/tr'; // path prefix for subpages
---

<footer class="relative bg-[var(--color-dark-bg)] overflow-hidden" role="contentinfo" aria-label="Site footer">

  <!-- Top divider -->
  <div class="section-divider"></div>

  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none" aria-hidden="true"></div>

  <!-- Main footer body -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">

      <!-- ===== Brand column ===== -->
      <div class="lg:col-span-2 space-y-5 reveal">

        <!-- Logo + name -->
        <a href={`/${lang === 'en' ? '' : lang}`} class="inline-flex items-center gap-3 group" aria-label="Glastok home">
          <div class="w-9 h-9 bg-brand-primary rounded-md flex items-center justify-center overflow-hidden shrink-0 transition-transform duration-300 group-hover:scale-105">
            <img src="/logo.png" alt="Glastok" class="w-7 h-7 object-contain" />
          </div>
          <span class="font-heading font-extrabold text-lg tracking-[2px] uppercase text-dark-text">
            GLASTOK
          </span>
        </a>

        <!-- Description -->
        <p class="footer-desc max-w-xs">
          {t(lang, 'footer.desc')}
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-3 pt-1">
          <!-- GitHub -->
          <a href="#" class="footer-social" aria-label="GitHub" rel="noopener noreferrer" target="_blank">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" class="footer-social" aria-label="LinkedIn" rel="noopener noreferrer" target="_blank">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Twitter / X -->
          <a href="#" class="footer-social" aria-label="Twitter / X" rel="noopener noreferrer" target="_blank">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>

      </div>

      <!-- ===== Product links ===== -->
      <div class="space-y-4 reveal reveal-delay-1">
        <h3 class="footer-col-heading">{t(lang, 'footer.product')}</h3>
        <ul class="space-y-2.5" role="list">
          <li><a href="#features" class="footer-link">{t(lang, 'nav.features')}</a></li>
          <li><a href="#how-it-works" class="footer-link">{t(lang, 'nav.howItWorks')}</a></li>
          <li><a href="#demo" class="footer-link">{t(lang, 'nav.demo')}</a></li>
          <li><a href="#contact" class="footer-link">{t(lang, 'nav.requestDemo')}</a></li>
        </ul>
      </div>

      <!-- ===== Company links ===== -->
      <div class="space-y-4 reveal reveal-delay-2">
        <h3 class="footer-col-heading">{t(lang, 'footer.company')}</h3>
        <ul class="space-y-2.5" role="list">
          <li><a href={`${p}/about/`} class="footer-link">{t(lang, 'footer.about')}</a></li>
          <li><a href={`${p}/careers/`} class="footer-link">{t(lang, 'footer.careers')}</a></li>
          <li><a href={`${p}/blog/`} class="footer-link">{t(lang, 'footer.blog')}</a></li>
          <li><a href="#contact" class="footer-link">{t(lang, 'nav.contact')}</a></li>
        </ul>
      </div>

      <!-- ===== Legal links ===== -->
      <div class="space-y-4 reveal reveal-delay-3">
        <h3 class="footer-col-heading">{t(lang, 'footer.legal')}</h3>
        <ul class="space-y-2.5" role="list">
          <li><a href={`${p}/privacy/`} class="footer-link">{t(lang, 'footer.privacy')}</a></li>
          <li><a href={`${p}/terms/`} class="footer-link">{t(lang, 'footer.terms')}</a></li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="relative z-10 border-t border-[var(--color-dark-border)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">

        <!-- Copyright -->
        <div class="flex flex-col sm:flex-row items-center gap-1 sm:gap-3">
          <p class="footer-copyright">
            &copy; {currentYear} Glastok. {t(lang, 'footer.rights')}
          </p>
          <span class="hidden sm:block footer-divider" aria-hidden="true"></span>
          <a href="https://mfsyazilim.com" target="_blank" rel="noopener noreferrer" class="footer-bottom-link hover:text-brand-primary">
            {t(lang, 'footer.mfs')}
          </a>
        </div>

        <!-- Bottom links -->
        <nav class="flex items-center gap-5" aria-label="Footer legal navigation">
          <a href={`${p}/privacy/`} class="footer-bottom-link">{t(lang, 'footer.privacy')}</a>
          <span class="footer-divider" aria-hidden="true"></span>
          <a href={`${p}/terms/`} class="footer-bottom-link">{t(lang, 'footer.terms')}</a>
          <span class="footer-divider" aria-hidden="true"></span>
          <a href="#contact" class="footer-bottom-link">{t(lang, 'nav.contact')}</a>
        </nav>

      </div>
    </div>
  </div>

</footer>

<style>
  .footer-desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-dark-text-muted);
  }

  .footer-col-heading {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-dark-text);
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-dark-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-block;
  }
  .footer-link:hover {
    color: var(--color-brand-primary);
  }

  .footer-social {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--color-dark-surface-alt);
    border: 1px solid var(--color-dark-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-dark-text-muted);
    text-decoration: none;
    transition: all 0.2s var(--ease-out-expo);
  }
  .footer-social:hover {
    color: var(--color-brand-primary);
    border-color: rgba(255,214,0,0.3);
    background: rgba(255,214,0,0.06);
    transform: translateY(-2px);
  }
  .footer-social:focus-visible {
    outline: 2px solid var(--color-brand-primary);
    outline-offset: 2px;
  }

  .footer-copyright {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-dark-text-dim);
  }

  .footer-bottom-link {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-dark-text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-bottom-link:hover { color: var(--color-brand-primary); }
  .footer-bottom-link:focus-visible {
    outline: 2px solid var(--color-brand-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .footer-divider {
    display: block;
    width: 1px;
    height: 12px;
    background: var(--color-dark-border);
  }
</style>
