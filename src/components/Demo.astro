<script>
  (function() {
    const sidebar = document.getElementById('demo-sidebar');
    const sidebarAside = document.getElementById('demo-sidebar-aside');
    const demoApp = document.getElementById('demo-app');
    const addressBar = document.getElementById('demo-address-bar');
    const mobileToggle = document.getElementById('demo-mobile-toggle');
    const backdrop = document.getElementById('demo-backdrop');
    if (!sidebar || !demoApp) return;

    const navItems = sidebar.querySelectorAll<HTMLElement>('.sidebar-nav-item[data-panel]');
    const panels = demoApp.querySelectorAll<HTMLElement>('.demo-panel');

    function closeMobileSidebar() {
      sidebarAside?.classList.remove('mobile-open');
      backdrop?.classList.add('hidden');
    }

    function openMobileSidebar() {
      sidebarAside?.classList.add('mobile-open');
      backdrop?.classList.remove('hidden');
    }

    mobileToggle?.addEventListener('click', () => {
      const isOpen = sidebarAside?.classList.contains('mobile-open');
      if (isOpen) closeMobileSidebar();
      else openMobileSidebar();
    });

    backdrop?.addEventListener('click', closeMobileSidebar);

    function activatePanel(panelId: string) {
      navItems.forEach(item => item.classList.remove('sidebar-nav-active'));
      panels.forEach(p => p.classList.remove('active'));

      const targetNav = sidebar.querySelector<HTMLElement>(`[data-panel="${panelId}"]`);
      const targetPanel = document.getElementById(`panel-${panelId}`);

      if (targetNav) {
        targetNav.classList.add('sidebar-nav-active');
        if (addressBar && targetNav.dataset.url) {
          addressBar.textContent = targetNav.dataset.url;
        }
      }
      if (targetPanel) targetPanel.classList.add('active');
    }

    navItems.forEach(item => {
      item.addEventListener('click', () => {
        const panelId = item.dataset.panel;
        if (panelId) activatePanel(panelId);
        closeMobileSidebar();
      });
    });
  })();
</script>
