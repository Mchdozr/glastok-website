---
import { t } from '../i18n/translations';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section id="demo" class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="label-tag block mb-4">{t(lang, 'demo.tag')}</span>
      <h2 class="heading-lg text-4xl md:text-5xl text-[var(--color-dark-text)]">
        {t(lang, 'demo.title')} <span class="text-[var(--color-brand-primary)]">{t(lang, 'demo.titleHighlight')}</span>
      </h2>
    </div>

    <div class="reveal reveal-delay-2">
      <div class="glass-card overflow-hidden border border-[var(--color-dark-border-light)]" style="border-radius: 12px;" id="demo-app">

        <!-- Browser top bar -->
        <div class="flex items-center gap-3 px-5 py-3.5 border-b border-[var(--color-dark-border)] bg-[var(--color-dark-surface-alt)]">
          <div class="flex items-center gap-2 shrink-0">
            <span class="w-3 h-3 rounded-full bg-[var(--color-danger)] opacity-80 block"></span>
            <span class="w-3 h-3 rounded-full bg-[var(--color-warning)] opacity-80 block"></span>
            <span class="w-3 h-3 rounded-full bg-[var(--color-success)] opacity-80 block"></span>
          </div>
          <div class="flex-1 flex items-center gap-2 bg-[var(--color-dark-bg)] border border-[var(--color-dark-border)] rounded-md px-3 py-1.5 max-w-xs mx-auto">
            <svg class="w-3 h-3 text-[var(--color-dark-text-muted)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            <span id="demo-address-bar" style="font-family: var(--font-mono); font-size: 11px; color: var(--color-dark-text-muted);">app.glastok.com/dashboard</span>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="w-5 h-5 rounded bg-[var(--color-dark-border)] block opacity-50"></span>
            <span class="w-5 h-5 rounded bg-[var(--color-dark-border)] block opacity-50"></span>
          </div>
        </div>

        <!-- App shell: sidebar + content -->
        <div class="flex min-h-[520px] bg-[var(--color-dark-bg)]">

          <!-- Sidebar -->
          <aside class="hidden sm:flex flex-col w-[200px] shrink-0 border-r border-[var(--color-dark-border)] bg-[var(--color-dark-surface)] py-4">
            <div class="flex items-center gap-2 px-4 mb-6">
              <span class="w-6 h-6 rounded bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="var(--color-dark-bg)">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
              </span>
              <span style="font-family: var(--font-heading); font-weight: 700; font-size: 13px; color: var(--color-dark-text); letter-spacing: 1px;">GLASTOK</span>
            </div>
            <nav class="flex flex-col gap-0.5 px-2 overflow-y-auto" id="demo-sidebar">
              <span class="sidebar-nav-item sidebar-nav-active" data-panel="dashboard" data-url="app.glastok.com/dashboard">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Ana Sayfa
              </span>
              <span class="sidebar-nav-item" data-panel="products" data-url="app.glastok.com/products">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Ürünler
              </span>
              <span class="sidebar-nav-item" data-panel="categories" data-url="app.glastok.com/categories">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                Kategoriler
              </span>
              <span class="sidebar-nav-item" data-panel="warehouses" data-url="app.glastok.com/warehouses">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                Depolar
              </span>
              <div class="my-1.5 mx-1 h-px bg-[var(--color-dark-border)] opacity-50"></div>
              <span class="sidebar-nav-item" data-panel="movements" data-url="app.glastok.com/stock-movements">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                Stok Hareketleri
              </span>
              <span class="sidebar-nav-item" data-panel="stock-report" data-url="app.glastok.com/reports/stock">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Stok Raporu
              </span>
              <span class="sidebar-nav-item" data-panel="advanced-reports" data-url="app.glastok.com/reports/advanced">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
                Gelişmiş Raporlar
              </span>
              <div class="my-1.5 mx-1 h-px bg-[var(--color-dark-border)] opacity-50"></div>
              <span class="sidebar-nav-item" data-panel="settings" data-url="app.glastok.com/settings">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Ayarlar
              </span>
              <div class="my-1.5 mx-1 h-px bg-[var(--color-dark-border)] opacity-50"></div>
              <span class="sidebar-nav-item" data-panel="import" data-url="app.glastok.com/admin/import">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                İçe Aktarma
              </span>
              <span class="sidebar-nav-item" data-panel="users" data-url="app.glastok.com/admin/users">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Kullanıcılar
              </span>
              <span class="sidebar-nav-item" data-panel="activity-log" data-url="app.glastok.com/admin/activity-log">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                Aktivite Takip
              </span>
            </nav>
            <div class="mt-auto px-3 pt-4 border-t border-[var(--color-dark-border)]">
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                  <span style="font-family: var(--font-heading); font-size: 10px; font-weight: 700; color: var(--color-dark-bg);">AD</span>
                </div>
                <div>
                  <p style="font-family: var(--font-heading); font-size: 11px; font-weight: 600; color: var(--color-dark-text);">Admin</p>
                  <p style="font-size: 9px; color: var(--color-dark-text-muted);">Super Admin</p>
                </div>
              </div>
            </div>
          </aside>

          <!-- Content panels -->
          <div class="flex-1 overflow-auto">

            <!-- DASHBOARD -->
            <div class="demo-panel active" id="panel-dashboard">
              <div class="p-5 space-y-5">
                <div class="flex items-center justify-between">
                  <div><h3 class="mock-page-title">Dashboard</h3><p class="mock-page-sub">Hoş geldiniz, Admin</p></div>
                  <span class="mock-badge-yellow">Canlı</span>
                </div>
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                  <div class="mock-stat-card" style="border-left-color: var(--color-brand-primary);"><span class="mock-stat-num">847</span><span class="mock-stat-label">Toplam Ürün</span></div>
                  <div class="mock-stat-card" style="border-left-color: var(--color-info);"><span class="mock-stat-num">3</span><span class="mock-stat-label">Depo</span></div>
                  <div class="mock-stat-card" style="border-left-color: var(--color-success);"><span class="mock-stat-num">156</span><span class="mock-stat-label">Bugünkü Hareketler</span></div>
                  <div class="mock-stat-card" style="border-left-color: var(--color-danger);"><span class="mock-stat-num">12</span><span class="mock-stat-label">Düşük Stok Uyarısı</span></div>
                </div>
                <div>
                  <div class="flex items-center justify-between mb-2"><span class="mock-table-header-label">Son Hareketler</span><span class="mock-link">Tümünü Gör</span></div>
                  <div class="mock-table-wrap">
                    <div class="mock-table-head"><span>Ürün</span><span>Tip</span><span>Miktar</span><span>Depo</span><span>Saat</span></div>
                    <div class="mock-table-row"><span class="mock-cell-primary">PRD-001 — Laptop</span><span><span class="mock-badge-green">GİRİŞ</span></span><span class="mock-cell-num">+25</span><span class="mock-cell-muted">Ana Depo</span><span class="mock-cell-muted">14:32</span></div>
                    <div class="mock-table-row"><span class="mock-cell-primary">PRD-002 — Akıllı Telefon</span><span><span class="mock-badge-red">ÇIKIŞ</span></span><span class="mock-cell-num">-18</span><span class="mock-cell-muted">Şube Deposu</span><span class="mock-cell-muted">13:18</span></div>
                    <div class="mock-table-row"><span class="mock-cell-primary">PRD-008 — Basic T-Shirt</span><span><span class="mock-badge-blue">TRANSFER</span></span><span class="mock-cell-num">50</span><span class="mock-cell-muted">İST → ANK</span><span class="mock-cell-muted">12:05</span></div>
                  </div>
                </div>
                <div class="mock-alert-strip">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                  12 ürün minimum stok seviyesinin altında — <span style="color: var(--color-brand-primary); font-weight: 600;">Uyarıları Gör</span>
                </div>
              </div>
            </div>

            <!-- ÜRÜNLER -->
            <div class="demo-panel" id="panel-products">
              <div class="p-5 space-y-4">
                <div class="flex items-center justify-between"><h3 class="mock-page-title">Ürünler</h3><button class="mock-btn-primary">+ Ürün Ekle</button></div>
                <div class="flex gap-2">
                  <div class="flex-1 flex items-center gap-2 mock-input-wrap"><svg class="w-3.5 h-3.5 shrink-0" style="color: var(--color-dark-text-muted)" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><span style="color: var(--color-dark-text-dim); font-size: 12px;">Ürün, barkod ara...</span></div>
                  <span class="mock-filter-btn">Kategori</span><span class="mock-filter-btn">Depo</span>
                </div>
                <div class="mock-table-wrap">
                  <div class="mock-table-head" style="grid-template-columns: 1fr 1.5fr 1fr 0.8fr 0.8fr 0.6fr;"><span>Kod</span><span>Ürün Adı</span><span>Kategori</span><span>Fiyat</span><span>Stok</span><span>Durum</span></div>
                  <div class="mock-table-row" style="grid-template-columns: 1fr 1.5fr 1fr 0.8fr 0.8fr 0.6fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">PRD-001</span><span class="mock-cell-primary">Laptop</span><span><span class="mock-badge-outline">Elektronik</span></span><span class="mock-cell-num">₺15.000</span><span class="mock-cell-num">42</span><span><span class="mock-badge-green">OK</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 1fr 1.5fr 1fr 0.8fr 0.8fr 0.6fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">PRD-002</span><span class="mock-cell-primary">Akıllı Telefon</span><span><span class="mock-badge-outline">Elektronik</span></span><span class="mock-cell-num">₺8.500</span><span class="mock-cell-num">3</span><span><span class="mock-badge-red">LOW</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 1fr 1.5fr 1fr 0.8fr 0.8fr 0.6fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">PRD-005</span><span class="mock-cell-primary">Zeytinyağı 1L</span><span><span class="mock-badge-outline">Gıda</span></span><span class="mock-cell-num">₺320</span><span class="mock-cell-num">180</span><span><span class="mock-badge-green">OK</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 1fr 1.5fr 1fr 0.8fr 0.8fr 0.6fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">PRD-009</span><span class="mock-cell-primary">Slim Gömlek</span><span><span class="mock-badge-outline">Giyim</span></span><span class="mock-cell-num">₺450</span><span class="mock-cell-num">0</span><span><span class="mock-badge-dim">TÜKENDİ</span></span></div>
                </div>
                <div class="flex items-center justify-between mt-2"><span style="font-size: 11px; color: var(--color-dark-text-muted);">1–4 / 847 ürün gösteriliyor</span><div class="flex gap-1"><span class="mock-page-btn active">1</span><span class="mock-page-btn">2</span><span class="mock-page-btn">3</span><span style="font-size: 11px; color: var(--color-dark-text-dim); padding: 0 4px;">...</span><span class="mock-page-btn">212</span></div></div>
              </div>
            </div>

            <!-- KATEGORİLER -->
            <div class="demo-panel" id="panel-categories">
              <div class="p-5 space-y-4">
                <div class="flex items-center justify-between"><div><h3 class="mock-page-title">Kategoriler</h3><p class="mock-page-sub">Ürün kategorilerini yönetin</p></div><button class="mock-btn-primary">+ Yeni Kategori</button></div>
                <div class="mock-table-wrap">
                  <div class="mock-table-head" style="grid-template-columns: 0.5fr 1.5fr 2fr 0.8fr 0.6fr;"><span>ID</span><span>Ad</span><span>Açıklama</span><span>Durum</span><span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.5fr 1.5fr 2fr 0.8fr 0.6fr;"><span class="mock-cell-num">1</span><span class="mock-cell-primary">Elektronik</span><span class="mock-cell-muted">Tüketici elektronik ürünleri</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.5fr 1.5fr 2fr 0.8fr 0.6fr;"><span class="mock-cell-num">2</span><span class="mock-cell-primary">Gıda</span><span class="mock-cell-muted">Gıda ve içecek ürünleri</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.5fr 1.5fr 2fr 0.8fr 0.6fr;"><span class="mock-cell-num">3</span><span class="mock-cell-primary">Giyim</span><span class="mock-cell-muted">Tekstil ve giyim ürünleri</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                </div>
              </div>
            </div>

            <!-- DEPOLAR -->
            <div class="demo-panel" id="panel-warehouses">
              <div class="p-5 space-y-4">
                <div class="flex items-center justify-between"><div><h3 class="mock-page-title">Depolar</h3><p class="mock-page-sub">Depo yönetimi</p></div><button class="mock-btn-primary">+ Yeni Depo</button></div>
                <div class="mock-table-wrap">
                  <div class="mock-table-head" style="grid-template-columns: 0.8fr 1.2fr 2fr 0.7fr 0.5fr;"><span>Kod</span><span>Ad</span><span>Adres</span><span>Durum</span><span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.8fr 1.2fr 2fr 0.7fr 0.5fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">DEPO-001</span><span class="mock-cell-primary">Ana Depo</span><span class="mock-cell-muted">İstanbul, Tuzla Organize Sanayi Bölgesi</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.8fr 1.2fr 2fr 0.7fr 0.5fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">DEPO-002</span><span class="mock-cell-primary">Şube Deposu</span><span class="mock-cell-muted">Ankara, Ostim Organize Sanayi Bölgesi</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                  <div class="mock-table-row" style="grid-template-columns: 0.8fr 1.2fr 2fr 0.7fr 0.5fr;"><span style="font-family: var(--font-mono); font-size: 11px; color: var(--color-brand-primary);">DEPO-003</span><span class="mock-cell-primary">E-Ticaret Deposu</span><span class="mock-cell-muted">İstanbul, Esenyurt Lojistik Merkez</span><span><span class="mock-badge-green">Aktif</span></span><span class="flex gap-2"><span class="mock-link">✎</span><span class="mock-link" style="color: var(--color-danger);">✕</span></span></div>
                </div>
              </div>
            </div>

            <!-- STOK HAREKETLERİ -->
            <div class="demo-panel" id="panel-movements">
              <div class="p-5 space-y-4">
                <div class="flex items-center justify-between"><h3 class="mock-page-title">Stok Hareketleri</h3><button class="mock-btn-primary">+ Yeni Hareket</button></div>
                <div class="flex flex-wrap gap-2">
                  <span class="mock-filter-btn mock-filter-active">Tüm Tipler</span><span class="mock-filter-btn">Giriş</span><span class="mock-filter-btn">Çıkış</span><span class="mock-filter-btn">Transfer</span><span class="mock-filter-btn">Düzeltme</span><span class="mock-filter-btn">İade</span>
                  <div class="ml-auto flex gap-2"><span class="mock-filter-btn">Tarih Aralığı</span><span class="mock-filter-btn">Depo</span></div>
