---
import SubpageLayout from '../../layouts/SubpageLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'tr';

const values = [
  { key: 'simplicity', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>` },
  { key: 'reliability', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>` },
  { key: 'security', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>` },
  { key: 'speed', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>` },
];
---

<SubpageLayout lang={lang} title={t(lang, 'about.title')}>
  <!-- Header -->
  <div class="mb-16">
    <h1 class="heading-lg text-4xl md:text-5xl mb-4">{t(lang, 'about.title')}</h1>
    <p class="text-lg text-dark-text-muted leading-relaxed">{t(lang, 'about.subtitle')}</p>
  </div>

  <!-- Mission -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold mb-4 text-brand-primary">{t(lang, 'about.mission.title')}</h2>
    <p class="text-base leading-relaxed text-dark-text-muted">{t(lang, 'about.mission.desc')}</p>
  </section>

  <!-- Story -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold mb-4 text-brand-primary">{t(lang, 'about.story.title')}</h2>
    <p class="text-base leading-relaxed text-dark-text-muted">{t(lang, 'about.story.desc')}</p>
  </section>

  <!-- Values -->
  <section class="mb-16">
    <h2 class="font-heading text-2xl font-bold mb-8 text-brand-primary">{t(lang, 'about.values.title')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {values.map((v) => (
        <div class="glass-card p-6 border border-dark-border-light">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background: rgba(255,214,0,0.1);">
            <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={v.icon} />
            </svg>
          </div>
          <h3 class="font-heading text-base font-bold mb-2 text-dark-text">{t(lang, `about.values.${v.key}` as any)}</h3>
          <p class="text-sm text-dark-text-muted leading-relaxed">{t(lang, `about.values.${v.key}Desc` as any)}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="glass-card p-8 md:p-10 text-center border border-dark-border-light">
    <h2 class="font-heading text-2xl font-bold mb-4">{t(lang, 'about.cta')}</h2>
    <a href="/#contact" class="btn-primary inline-flex">
      {t(lang, 'about.ctaBtn')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
    </a>
  </section>
</SubpageLayout>
