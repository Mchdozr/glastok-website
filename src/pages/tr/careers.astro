---
import SubpageLayout from '../../layouts/SubpageLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'tr';

const perks = [
  { key: 'remote', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
  { key: 'growth', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>` },
  { key: 'impact', icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>` },
];
---

<SubpageLayout lang={lang} title={t(lang, 'careers.title')}>
  <!-- Header -->
  <div class="mb-16">
    <h1 class="heading-lg text-4xl md:text-5xl mb-4">{t(lang, 'careers.title')}</h1>
    <p class="text-lg text-dark-text-muted leading-relaxed">{t(lang, 'careers.subtitle')}</p>
  </div>

  <!-- No openings banner -->
  <section class="glass-card p-8 md:p-10 text-center border border-dark-border-light mb-16">
    <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5" style="background: rgba(255,214,0,0.1);">
      <svg class="w-7 h-7 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </div>
    <h2 class="font-heading text-2xl font-bold mb-3">{t(lang, 'careers.noOpenings')}</h2>
    <p class="text-base text-dark-text-muted leading-relaxed max-w-lg mx-auto mb-6">{t(lang, 'careers.noOpeningsDesc')}</p>
    <a href="mailto:info@glastok.com" class="btn-primary inline-flex">
      {t(lang, 'careers.sendCv')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </a>
  </section>

  <!-- Perks -->
  <section>
    <h2 class="font-heading text-2xl font-bold mb-8 text-brand-primary">{t(lang, 'careers.perks.title')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {perks.map((p) => (
        <div class="glass-card p-6 border border-dark-border-light">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4" style="background: rgba(255,214,0,0.1);">
            <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={p.icon} />
            </svg>
          </div>
          <h3 class="font-heading text-base font-bold mb-2 text-dark-text">{t(lang, `careers.perks.${p.key}` as any)}</h3>
          <p class="text-sm text-dark-text-muted leading-relaxed">{t(lang, `careers.perks.${p.key}Desc` as any)}</p>
        </div>
      ))}
    </div>
  </section>
</SubpageLayout>
