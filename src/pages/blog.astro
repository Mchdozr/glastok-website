---
import SubpageLayout from '../layouts/SubpageLayout.astro';
import { t } from '../i18n/translations';

const lang = 'en';
---

<SubpageLayout lang={lang} title={t(lang, 'blog.title')}>
  <div class="mb-16">
    <h1 class="heading-lg text-4xl md:text-5xl mb-4">{t(lang, 'blog.title')}</h1>
    <p class="text-lg text-dark-text-muted leading-relaxed">{t(lang, 'blog.subtitle')}</p>
  </div>

  <section class="glass-card p-8 md:p-12 text-center border border-dark-border-light">
    <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5" style="background: rgba(255,214,0,0.1);">
      <svg class="w-7 h-7 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
    </div>
    <h2 class="font-heading text-2xl font-bold mb-3">{t(lang, 'blog.comingSoon')}</h2>
    <p class="text-base text-dark-text-muted leading-relaxed max-w-lg mx-auto mb-6">{t(lang, 'blog.comingSoonDesc')}</p>
    <a href="/#contact" class="btn-secondary inline-flex">
      {t(lang, 'blog.notify')}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
    </a>
  </section>
</SubpageLayout>
